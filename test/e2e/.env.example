# E2E Test Environment Variables
# Copy this file to .env and fill in real values before running e2e tests.
# Variables without values are optional.

# OpenAI provider (required for most tests)
E2E_OPENAI_API_KEY=sk-your-openai-key
E2E_OPENAI_BASE_URL=
E2E_OPENAI_MODEL=gpt-4o-mini

# Anthropic provider (required for Anthropic/Claude tests)
E2E_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
E2E_ANTHROPIC_BASE_URL=
E2E_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# GitHub token (required for Copilot agent tests)
E2E_GITHUB_TOKEN=
