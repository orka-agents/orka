# Minimal Codex worker image for the Agent Substrate E2E.
#
# The workspace handoff uploads this worker binary into the Substrate actor.
# Keep it stripped and small so kind runners do not spend the test budget moving
# the full production image payload.
FROM --platform=$BUILDPLATFORM golang:1.26 AS builder

ARG TARGETARCH

WORKDIR /workspace

COPY go.mod go.sum ./
RUN go mod download

COPY api/ api/
COPY internal/ internal/
COPY workers/ workers/

RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH:-amd64} \
    go build -a -ldflags="-s -w" -o /out/worker ./workers/agent/codex

FROM gcr.io/distroless/static:nonroot

COPY --from=builder /out/worker /worker

USER 1000:1000
ENTRYPOINT ["/worker"]
